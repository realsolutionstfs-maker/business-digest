# Buttondown API key (required for sending newsletters)
# Get yours at: https://buttondown.com/settings/api
BUTTONDOWN_API_KEY=

# Brand settings
NEWSLETTER_NAME="Business Digest"
NEWSLETTER_TAGLINE="Three moves. Every Saturday. Zero noise."
DOMAIN=businessdigest.com

# Optional: monitoring email (smtp needed)
# ALERT_EMAIL=
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# LinkedIn API (for auto-publishing)
# LinkedIn App: https://www.linkedin.com/developers/
# LINKEDIN_CLIENT_ID=your_client_id
# LINKEDIN_CLIENT_SECRET=your_client_secret

# Log level
LOG_LEVEL=INFO
