# Buttondown API key (required for sending newsletters)
# Get yours at: https://buttondown.com/settings/api
BUTTONDOWN_API_KEY=

# Brand settings
NEWSLETTER_NAME="Business Digest"
NEWSLETTER_TAGLINE="Three moves. Every Saturday. Zero noise."
DOMAIN=businessdigest.com

# Optional: monitoring email (smtp needed)
# ALERT_EMAIL=
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Log level
LOG_LEVEL=INFO
