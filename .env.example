# =============================================================================
# AI MEDIA COMPANY — ENVIRONMENT CONFIGURATION
# =============================================================================
# Optional: Only Buttondown API key is needed if you want to send newsletters.
# All content generation works fully offline with embedded templates.
# --- DISTRIBUTION ---
BUTTONDOWN_API_KEY=your_buttondown_api_key
# Signup: https://buttondown.email/ → Settings → API Key
# Free tier: 100 subscribers, unlimited sends
# --- BRAND ---
NEWSLETTER_NAME="Business Digest"
NEWSLETTER_TAGLINE="Three moves. Every Saturday. Zero noise."
DOMAIN=yourdomain.com
# --- EXECUTION ---
LOG_LEVEL=INFO
